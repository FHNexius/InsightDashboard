# NikoHealth API credentials — server-side only, never exposed to the browser.
# Copy this file to .env.local and fill in real values.

# Your NikoHealth API key / token.
NIKO_API_KEY=

# Base URL for the NikoHealth API (no trailing slash).
# TODO: confirm the exact base URL from NikoHealth's Swagger docs.
NIKO_API_BASE_URL=https://api.nikohealth.com
